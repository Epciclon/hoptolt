{
  "name": "rabbit-management-system-backend",
  "version": "1.0.0",
  "description": "Backend for Rabbit Management System",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "create-admin": "node src/utils/createAdmin.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch --coverage",
    "test:ci": "jest --coverage --ci --watchAll=false --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "html-pdf-node": "^1.0.8",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "mongoose": "^5.10.9",
    "puppeteer": "^24.15.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^2.0.4",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/app.js",
      "!src/scripts/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "verbose": true,
    "forceExit": true,
    "detectOpenHandles": true
  },
  "license": "MIT"
}
